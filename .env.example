# Ship Plugin — Environment Variables
#
# Copy this file to .env and fill in your values.
# This file is committed to the repo as a reference.
# .env is gitignored and should NEVER be committed.

# SHIP_ROOT (required for OpenClaw)
# Absolute path to the ship plugin directory on your machine.
# Used by the OpenClaw adapter to locate skill files.
# Claude Code does not need this — it uses ${CLAUDE_PLUGIN_ROOT} automatically.
SHIP_ROOT=
